# Copia este archivo a .env y ajusta los valores

# Puerto del servidor (default: 8000)
PORT=8000

# Ruta a la base de datos SQLite (default: solguard.db)
DATABASE_URL=solguard.db

# Solana RPC — devnet | mainnet-beta | localnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# Program ID desplegado en Solana
SOLANA_PROGRAM_ID=9cuFsdRhYpm2JjJ1NbzA8W2nG5tSgzHto3ABt5qycsN9

# Ruta al keypair del Oracle Signer (quien firma las txs)
ORACLE_KEYPAIR_PATH=/home/codespace/.config/solana/id.json

# Cargar wallets de demo al arrancar (true en dev, false en prod)
SEED_DEMO_DATA=true
